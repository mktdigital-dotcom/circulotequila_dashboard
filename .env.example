# ── Conexión a NocoDB (para la serverless function /api/nocodb) ──────────────
# En Vercel: Project → Settings → Environment Variables.
# IMPORTANTE: nómbrala SIN el prefijo VITE_ para que el token quede solo del lado
# del servidor (nunca expuesto en el navegador).

NOCODB_TOKEN=tu_api_token_de_nocodb_aqui
# Opcional (ya trae valor por defecto):
# NOCODB_HOST=https://n8n-nocodb.pzqn6b.easypanel.host

# ── Candado de acceso del dashboard (RECOMENDADO en producción) ──────────────
# Si defines DASHBOARD_TOKEN, /api/nocodb exige el header x-app-key con este
# valor (deny-by-default) y el dashboard pide una clave de acceso. Sin esta
# variable, el endpoint queda ABIERTO. Usa una cadena larga y aleatoria.
# DASHBOARD_TOKEN=pon_aqui_una_clave_larga_aleatoria

# ── Webhook del simulador (proxy /api/agente) ────────────────────────────────
# El simulador llama a /api/agente, que reenvía a este webhook del lado servidor
# (la URL nunca llega al navegador). Apúntalo a un webhook SEPARADO del de
# producción (ej. circulo-simulador) para poder blindar producción sin romper
# el simulador. Si no se define, cae al webhook por defecto.
# WEBHOOK_SIMULADOR=https://n8n-n8n.pzqn6b.easypanel.host/webhook/circulo-simulador
# Secreto opcional que n8n valida (Header Auth) en el nodo Webhook:
# WEBHOOK_SECRET=pon_aqui_un_secreto_largo

# ── Meta Marketing API (opcional · panel de anuncios) ────────────────────────
# META_ACCESS_TOKEN=...
# META_AD_ACCOUNT_ID=act_...
